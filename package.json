{
  "name": "strawberrybear-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "prepare": "husky",
    "ci:version": "changeset version",
    "ci:publish": "turbo run build && changeset publish",
    "nikki": "pnpm --filter @strawberrybear/infinity-nikki-player tauri dev",
    "nikki:clean": "pnpm --filter @strawberrybear/infinity-nikki-player tauri:dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
